{
    "configurations": [
        {
            "type": "java",
            "name": "KeyPairGeneratorUtil",
            "request": "launch",
            "mainClass": "com.urlshortener.utils.KeyPairGeneratorUtil",
            "projectName": "shared"
        },
        {
            "type": "java",
            "name": "PemUtil",
            "request": "launch",
            "mainClass": "com.urlshortener.utils.PemUtil",
            "projectName": "shared"
        },
        {
            "type": "java",
            "name": "Spring Boot-ShortenerApplication<shortener>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.main.shortener.ShortenerApplication",
            "projectName": "shortener",
            "args": "",
            "envFile": "${workspaceFolder}/shortener/.env.dev"
        },
        {
            "type": "java",
            "name": "Spring Boot-RedirectorApplication<redirector>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.main.redirector.RedirectorApplication",
            "projectName": "redirector",
            "args": "",
            "envFile": "${workspaceFolder}/redirector/.env.dev"
        },
        {
            "type": "java",
            "name": "Spring Boot-GatewayApplication<gateway>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.main.gateway.GatewayApplication",
            "projectName": "gateway",
            "args": "",
            "envFile": "${workspaceFolder}/gateway/.env.dev"
        },
        {
            "type": "java",
            "name": "Spring Boot-AuthApplication<auth>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.main.auth.AuthApplication",
            "projectName": "auth",
            "args": "",
            "envFile": "${workspaceFolder}/auth/.env.dev",
            "vmArgs": " -Dcom.sun.management.jmxremote -Dcom.sun.management.jmxremote.port=59494 -Dcom.sun.management.jmxremote.authenticate=false -Dcom.sun.management.jmxremote.ssl=false -Dspring.jmx.enabled=true -Djava.rmi.server.hostname=localhost -Dspring.application.admin.enabled=true -Dspring.boot.project.name=auth"
        }
    ],
    "compounds": [
        {
            "name": "All Services",
            "configurations": [
                "Spring Boot-ShortenerApplication<shortener>",
                "Spring Boot-RedirectorApplication<redirector>",
                "Spring Boot-GatewayApplication<gateway>",
                "Spring Boot-AuthApplication<auth>"
            ],
            "stopAll": true,
        }
    ]
}
DB_URL=jdbc:h2:mem:mydb
DB_USER=sa
DB_PASSWORD=password
DB_DRIVER=org.h2.Driver
DB_PLATFORM=org.hibernate.dialect.H2Dialect

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

JWT_PUBLIC_KEY_PATH= auth/src/main/resources/jwt-private-pkcs8.pem
JWT_PRIVATE_KEY_PATH= auth/src/main/resources/jwt-private-pkcs8.pem
JWT_ALG=RS256
JWT_EXPIRATION_TIME=900000

